<+><!DOCTYPE html>\n<html lang=\"en\">\n    <head>\n        <meta charset=\"UTF-8\">\n        <title>News Page</title>\n        <link href=\"https://fonts.googleapis.com/css2?family=Inter&display=swap\" rel=\"stylesheet\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0\" />\n        <script src=\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\"></script>\n    </head>\n    <body>\n        <div class=\"w-full max-w-[1920px] h-full bg-[#141414]\">\n            <!--header-->\n            <!-- Top bar -->\n            <div class=\"flex justify-center\n            gap-1 min-[391px]:gap-[12px] py-5 bg-[#141414]\">\n                <p class=\"text-[#98989A] font-[Inter]\n                text-xs min-[391px]:text-sm min-[1441px]:text-lg\n                leading-[150%] tracking-[-0.03em]\">\n                    Subscribe to our Newsletter For New & latest Blogs and Resources\n                </p>\n                <img class=\"w-3 h-3 min-[391px]:w-5 min-[391px]:h-5 min-[1441px]:w-6 min-[1441px]:h-6\"\n                     src=\"icons/arrow-up-right.svg\"\n                     alt=\"arrow\">\n            </div>\n            <!-- Main header -->\n            <div class=\"relative bg-[#1A1A1A] h-[103px] flex items-center justify-center w-full\n            border-y border-[#262626]\">\n                <img class=\"flex absolute\n                right-4 min-[391px]:right-20 min-[1441px]:right-[162px]\n                hidden cursor-pointer\n                min-[391px]:block w-[103px] min-[391px]:h-[41px] min-[1441px]:w-[137px] min-[1441px]:h-[55px]\"\n                     src=\"buttons/contact-us.svg\"\n                     alt=\"contact\">\n                <input\n                        type=\"checkbox\"\n                        id=\"menu\"\n                        hidden\n                        class=\"peer hidden\">\n                <img class=\"flex absolute\n                left-4 min-[391px]:left-20 min-[1441px]:left-[162px]\n                w-[125px] h-[35px]\n                min-[391px]:w-[143px] min-[391px]:h-10\n                min-[1441px]:w-[179px] min-[1441px]:h-[50px]\"\n                     src=\"logos/futuretech-logo.svg\"\n                     alt=\"logo\">\n                <label\n                        for=\"menu\"\n                        class=\"block sm:hidden absolute right-4 cursor-pointer\">\n                    <img\n                            src=\"buttons/menu.svg\"\n                            alt=\"menu\">\n                </label>\n                <!--nav bar-->\n                <nav class=\"absolute sm:static top-full right-0 w-full sm:w-auto bg-[#1A1A1A]\n                max-h-0 overflow-hidden\n                peer-checked:max-h-96 peer-checked:p-4\n                transition-all duration-300 sm:max-h-none\">\n                    <ul class=\"flex flex-col sm:flex-row gap-[12px]\n                    text-[#7E7E81]\">\n                        <li class=\"px-4 py-2 border border-transparent cursor-pointer\n                        hover:bg-[#141414] hover:border-[#333333] hover:font-bold hover:text-[#ffffff]\">\n                            Home\n                        </li>\n                        <li class=\"px-4 py-2 border border-transparent cursor-pointer\n                        hover:bg-[#141414] hover:border-[#333333] hover:font-bold hover:text-[#ffffff]\">\n                            News\n                        </li>\n                        <li class=\"px-4 py-2 border border-transparent cursor-pointer\n                        hover:bg-[#141414] hover:border-[#333333] hover:font-bold hover:text-[#ffffff]\">\n                            Podcasts\n                        </li>\n                        <li class=\"px-4 py-2 border border-transparent cursor-pointer\n                        hover:bg-[#141414] hover:border-[#333333] hover:font-bold hover:text-[#ffffff]\">\n                            Resources\n                        </li>\n                    </ul>\n                </nav>\n            </div>\n            <!--desktop-->\n            <div>\n                <div class=\"m-[16px] min-[391px]:m-20 min-[1441px]:m-[162px]\">\n                    <h1 class=\"text-[#FFFFFF]\n                    text-[28px] min-[391px]:text-[55px] min-[1441px]:text-[80px]\n                    leading-[130%] tracking-[-0.03em] font-medium font-[Kumbh Sans]\">\n                        Today's Headlines: Stay\n                    </h1>\n                    <div class=\"inline-block min-[391px]:flex min-[391px]:gap-10 min-[1441px]:gap-20 items-center\">\n                        <h1 class=\"flex text-[#FFFFFF]\n                        text-[28px] min-[391px]:text-[55px] min-[1441px]:text-[80px]\n                        leading-[130%] tracking-[-0.03em] font-medium font-[Kumbh Sans]\">\n                            Informed\n                        </h1>\n                        <p class=\"flex text-[#98989A]\n                        text-sm min-[391px]:text-base min-[1441px]:text-lg\n                        leading-[150%] tracking-[-0.03em] font-normal font-[Inter]\">\n                            Explore the latest news from around the world. We bring you up-to-the-mimutes updates on\n                            the most significant events, trends, and stories. Discover the world through our news\n                            coverage.\n                        </p>\n                    </div>\n                </div>\n                <!--Trending Stories-->\n                <div class=\"flex flex-col items-center\n                w-full max-w-[1920px]\n                min-[391px]:flex-row gap-20 items-center justify-center\n                border-y border-[#262626]\n                py-10 min-[391px]:py-15 min-[1441px]:py-20\">\n                    <img class=\"w-[358px] h-[213px] min-[391px]:w-[515px] min-[391px]:h-[325px] min-[1441px]:h-[427px] min-[1441px]:w-[515px] object-cover\"\n                         src=\"pictures/global-climate.svg\"\n                         alt=\"global-climate\">\n                    <div class=\"w-[358px] min-[391px]:w-[725px] min-[1441px]:w-[1001px] inline-block\">\n                        <h3 class=\"text-xl min-[391px]:text-2xl min-[1441px]:text-4xl\n                        leading-[150%] tracking-[-0.03em] text-[#FFFFFF] font-semibold\n                        pb-[6px] min-[391px]:pb-[14px] min-[1441px]:pb-[30px]\">\n                            Global Climate Summit Addresses Urgent Climate Action\n                        </h3>\n                        <p class=\"text-base min-[391px]:text-lg min-[1441px]:text-xl\n                        leading-[150%] tracking-[-0.03em]\n                        text-[#98989A] font-regular\">\n                            World leaders gathered at the Global Climate Summit to discuss urgent climate action, emissions reductions, and renewable energy targets.\n                        </p>\n\n                        <div class=\"text-base min-[391px]:text-lg min-[1441px]:text-xl\n                        leading-[150%] tracking-[-0.03em] font-regular\n                        flex gap-8 py-5 min-[391px]:py-[30px] min-[1441px]:py-[50px]\">\n                            <div>\n                                <p class=\"text-[#98989A]\">Category</p>\n                                <p class=\"text-[#FFFFFF]\">Environment</p>\n                            </div>\n                            <div>\n                                <p class=\"text-[#98989A]\">Publication Date</p>\n                                <p class=\"text-[#FFFFFF]\">October 10, 2023</p>\n                            </div>\n                            <div>\n                                <p class=\"text-[#98989A]\">Author</p>\n                                <p class=\"text-[#FFFFFF]\">Jane Smith</p>\n                            </div>\n                        </div>\n                        <div class=\"flex justify-between\">\n        